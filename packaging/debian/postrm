#!/bin/bash
set -e

case "$1" in
    purge)
        # Remove user (remove home contents too, if any)
        if getent passwd dyndynser >/dev/null 2>&1; then
            userdel dyndynser
        fi

        # Remove group
        if getent group dyndynser >/dev/null 2>&1; then
            groupdel dyndynser
        fi

        # Remove config dir and everything in it
        rm -rf /etc/dyndynser
        ;;

    remove|upgrade|failed-upgrade|abort-install|abort-upgrade|disappear)
        ;;

    *)
        echo "postrm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

exit 0